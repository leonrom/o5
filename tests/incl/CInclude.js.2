/* global document, window, console, Map*/
/*jshint asi:true  */
/*jshint esversion: 6*/
(function () {              // ---------------------------------------------- o5com/params
	'use strict'
	let C = null
	const olga5_modul = 'CInclude',
		o5include = 'o5include',
		timera = '<--------}   инициирован ' + olga5_modul,
		incls = {},
		act = {
			div: null,
			cnt: 0,
			DecFinish: function () {
				if (--this.cnt <= 0) {
					const rezs = [],
						head = `Обработка 'CInclude'`
					let ok = true
					for (const url in incls) {
						const incl = incls[url],
							err = (incl.err ? 'ERROR' : '')
						if (err) ok = false
						rezs.push({ url: url, err: err, status: incl.status, text: incl.text, undef: incl.undef })
					}
					if (C) {
						(ok ? C.ConsoleInfo : C.ConsleError)(head, rezs.length, rezs)
					} else {
						console.groupCollapsed(head)
						console.table(rezs)
						console.groupEnd()
					}
					console.timeEnd(timera)
					window.dispatchEvent(new window.Event(C.events.o5cinit_ + olga5_modul))
				}
			}
		},
		SelInclDests = () => {
			const tags = document.querySelectorAll("div[o5include]")
			for (const tag of tags) { // группировка по url'ам, чтобы не грузить лишнее
				const ref = tag.getAttribute(o5include),
					ss = ref.split('?'),
					url = ss[0].trim()
				if (!incls[url]) {
					incls[url] = { tagids: [], status: 0, statusText: '', err: false, undef: '' }
					Object.seal(incls[url])
				}
				incls[url].tagids.push({ tag: tag, id: (ss[1] ? ss[1] : '') })
				// tag.attributes.removeNamedItem(o5include)// 'это на потом: чтобы могло искать и обрабатывать вложенные
			}
		},
		OnLoad = function () {
			const xhr = this,
				url = shr._url,
				incl = incls[url],
				ok = xhr.status == 200

			Object.assign(incl, { status: xhr.status, text: xhr.statusTest, err: !ok })

			if (ok) {
				const s = xhr.responseText,
					m1 = s.match(/<body\.*>/),
					i1 = (m1 && m1.length > 0) ? (m1.index + m1[0].length) : 0,
					i2 = i1 > 0 ? s.lastIndexOf('</body') : s.length,
					res = (i1 > 0 ? s.substring(i1, i2) : s).trim()

				for (const tagid of incl.tagids) {
					if (tagid.id) {
						if (!act.div) { // первый и единственный раз
							act.div = document.createElement('div')
							// Object.assign(act.div.style, { visible: false, height: 0, width: 0 })
							// document.body.appendChild(act.div)
						}
						act.div.innerHTML = res

						const tag = act.div.querySelector(tagid.id)
						if (tag) tagid.tag.innerHTML = tag.innerHTML
						else {
							incl.undef += (incl.undef ? ',' : '') + tagid.id
							incl.err = true
						}
					} else
						tagid.tag.innerHTML = res
				}
			}
			act.DecFinish()
		},
		OnError = function () {
			const xhr = this,
				url = shr._url,
				incl = incls[url]

			Object.assign(incl, { status: xhr.status, text: 'ошибка OnError', err: true })
			act.DecFinish()
		},
		Includes = () => {
			console.time(timera)
			C = window.olga5.C
			SelInclDests()
			for (const url in incls) {
				const xhr = new XMLHttpRequest()
				Object.assign(xhr, {
					_url: url,
					onload: OnLoad,
					onerror: OnError,
					timeout: 10000,
					responseType: 'text',
					withCredentials: true,
				})

				act.cnt++
				xhr.open("get", url, true)
				xhr.send()
			}
		}

	const W = {
		modul: olga5_modul,
		Init: Includes,
	}
	Object.freeze(W)

	if (!window.olga5) window.olga5 = []
	window.olga5.push(W)

	console.log(`}---> загружен:  ${olga5_modul}.js`)
	const e = new window.Event('olga5_sload')
	e.modul = olga5_modul
	window.dispatchEvent(e)
})();
